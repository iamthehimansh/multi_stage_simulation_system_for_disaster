{"ts":"2026-04-15T08:50:24.146Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":10472,"action":"execute","params":{"action":"execute","code":"// Remove NavMeshSurface from every scene that has it, save as text.\nUnityEditor.EditorSettings.serializationMode = UnityEditor.SerializationMode.ForceText;\nstring[] scenePaths = {\n    \"Assets/_FightForLife/Scenes/Island_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/Island_flood_m.unity\",\n    \"Assets/_FightForLife/Scenes/Village_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/MainMenu.unity\",\n};\nstring report = \"\";\nforeach (var p in scenePaths) {\n    var scn = UnityEditor.SceneManagement.EditorSceneManager.OpenScene(p, UnityEditor.SceneManagement.OpenSceneMode.Single);\n    int removed = 0;\n    System.Action<UnityEngine.Transform> walk = null;\n    walk = (t) => {\n        var nms = t.GetComponent(\"Unity.AI.Navigation.NavMeshSurface\");\n        if (nms != null) { UnityEngine.Object.DestroyImmediate(nms); removed++; }\n        var nmm = t.GetComponent(\"Unity.AI.Navigation.NavMeshModifier\");\n        if (nmm != null) { UnityEngine.Object.DestroyImmediate(nmm); removed++; }\n        var nmml = t.GetComponent(\"Unity.AI.Navigation.NavMeshModifierVolume\");\n        if (nmml != null) { UnityEngine.Object.DestroyImmediate(nmml); removed++; }\n        var nml = t.GetComponent(\"Unity.AI.Navigation.NavMeshLink\");\n        if (nml != null) { UnityEngine.Object.DestroyImmediate(nml); removed++; }\n        for (int i = 0; i < t.childCount; i++) walk(t.GetChild(i));\n    };\n    foreach (var r in scn.GetRootGameObjects()) walk(r.transform);\n    if (removed > 0) {\n        UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scn);\n        UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scn, p, false);\n    }\n    var fi = new System.IO.FileInfo(p);\n    byte[] h = new byte[2];\n    using (var fs = System.IO.File.OpenRead(p)) { fs.Read(h, 0, 2); }\n    bool isText = h[0]=='%';\n    report += p+\" removed=\"+removed+\" isText=\"+isText+\" size=\"+fi.Length+\"\\n\";\n}\nreturn report;","safety_checks":false,"compiler":"auto"}}
