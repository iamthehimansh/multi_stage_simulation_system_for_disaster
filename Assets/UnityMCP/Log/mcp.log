{"ts":"2026-04-07T09:28:15.304Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":777,"action":"execute","params":{"action":"execute","code":"\nvar scene = UnityEngine.SceneManagement.SceneManager.GetActiveScene();\nvar result = $\"Active scene: {scene.name} | {scene.path}\\n\";\n\nvar roots = scene.GetRootGameObjects();\nresult += $\"Root objects: {roots.Length}\\n\";\nforeach (var r in roots)\n{\n    if (r.name.Contains(\"Player\") || r.name.Contains(\"Terrain\") || r.name.Contains(\"Camera\") || r.name.Contains(\"MANAGER\"))\n        result += $\"  {r.name}\\n\";\n}\n\nreturn result;\n","safety_checks":true,"compiler":"auto"}}
