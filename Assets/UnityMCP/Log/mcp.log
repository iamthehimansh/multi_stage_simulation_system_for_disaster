{"ts":"2026-04-11T18:19:15.974Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1917,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// Fix Swimming.fbx - use Walking avatar source\nvar swimImporter = UnityEditor.AssetImporter.GetAtPath(\"Assets/_FightForLife/Animations/Player/Swimming.fbx\") as UnityEditor.ModelImporter;\nvar walkImporter = UnityEditor.AssetImporter.GetAtPath(\"Assets/_FightForLife/Models/Player/Walking.fbx\") as UnityEditor.ModelImporter;\n\nif (swimImporter != null && walkImporter != null) {\n    // Get Walking avatar\n    var walkingAvatar = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEngine.Avatar>(\"Assets/_FightForLife/Models/Player/Walking.fbx\");\n    // Find the avatar sub-asset\n    foreach (var a in UnityEditor.AssetDatabase.LoadAllAssetsAtPath(\"Assets/_FightForLife/Models/Player/Walking.fbx\")) {\n        if (a is UnityEngine.Avatar) { walkingAvatar = (UnityEngine.Avatar)a; break; }\n    }\n    \n    if (walkingAvatar != null) {\n        swimImporter.animationType = UnityEditor.ModelImporterAnimationType.Human;\n        swimImporter.sourceAvatar = walkingAvatar;\n        \n        // Also set animation clip to loop\n        var clipAnims = swimImporter.defaultClipAnimations;\n        if (clipAnims.Length > 0) {\n            clipAnims[0].loopTime = true;\n            clipAnims[0].name = \"Swimming\";\n            swimImporter.clipAnimations = clipAnims;\n        }\n        \n        swimImporter.SaveAndReimport();\n        sb.AppendLine(\"Swimming.fbx fixed: using WalkingAvatar, looping, renamed clip to 'Swimming'\");\n    }\n}\n\n// Now update the animator Swimming state to use the reimported clip\nUnityEditor.AssetDatabase.Refresh();\nvar allClips = UnityEditor.AssetDatabase.LoadAllAssetsAtPath(\"Assets/_FightForLife/Animations/Player/Swimming.fbx\");\nUnityEngine.AnimationClip swimClip = null;\nforeach (var a in allClips) {\n    if (a is UnityEngine.AnimationClip && !a.name.StartsWith(\"__\")) {\n        swimClip = (UnityEngine.AnimationClip)a;\n        sb.AppendLine(\"Clip found: \" + swimClip.name + \" length=\" + swimClip.length);\n        break;\n    }\n}\n\n// Update controller\nif (swimClip != null) {\n    var controller = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEditor.Animations.AnimatorController>(\n        \"Assets/_FightForLife/Animations/PlayerAnimator.controller\");\n    if (controller != null) {\n        var sm = controller.layers[0].stateMachine;\n        foreach (var s in sm.states) {\n            if (s.state.name == \"Swimming\") {\n                s.state.motion = swimClip;\n                sb.AppendLine(\"Updated Swimming state motion to reimported clip\");\n                break;\n            }\n        }\n        UnityEditor.EditorUtility.SetDirty(controller);\n        UnityEditor.AssetDatabase.SaveAssets();\n    }\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
