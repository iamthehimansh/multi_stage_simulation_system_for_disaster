{"ts":"2026-04-15T09:51:50.799Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":139321,"action":"execute","params":{"action":"execute","code":"// Verify Unity state, then build menu-only as a guaranteed shipping fallback\nif (UnityEngine.Application.isPlaying) return \"playing\";\n\n// Set scenes: only MainMenu enabled\nvar scenesList = new System.Collections.Generic.List<UnityEditor.EditorBuildSettingsScene>();\nscenesList.Add(new UnityEditor.EditorBuildSettingsScene(\"Assets/_FightForLife/Scenes/MainMenu.unity\", true));\nscenesList.Add(new UnityEditor.EditorBuildSettingsScene(\"Assets/_FightForLife/Scenes/Island_Flood.unity\", true));\nscenesList.Add(new UnityEditor.EditorBuildSettingsScene(\"Assets/_FightForLife/Scenes/Village_Flood.unity\", true));\nscenesList.Add(new UnityEditor.EditorBuildSettingsScene(\"Assets/_FightForLife/Scenes/Island_flood_m.unity\", true));\nUnityEditor.EditorBuildSettings.scenes = scenesList.ToArray();\n\n// Ensure Island_Flood is restored from backup (from earlier no-terrain test)\nstring bak = \"H:/fight-for-life-unity/Assets/_FightForLife/Scenes/Island_Flood.bak\";\nstring sceneFile = \"H:/fight-for-life-unity/Assets/_FightForLife/Scenes/Island_Flood.unity\";\nif (System.IO.File.Exists(bak)) {\n    System.IO.File.Copy(bak, sceneFile, true);\n    UnityEditor.AssetDatabase.ImportAsset(\"Assets/_FightForLife/Scenes/Island_Flood.unity\", UnityEditor.ImportAssetOptions.ForceUpdate);\n}\n\n// Build\nstring projRoot = System.IO.Path.GetDirectoryName(UnityEngine.Application.dataPath);\nstring cache = projRoot + \"/Library/PlayerDataCache\";\nif (System.IO.Directory.Exists(cache)) System.IO.Directory.Delete(cache, true);\nstring buildDir = \"H:/fight-for-life-unity/Builds/FightForLife_Win\";\nif (System.IO.Directory.Exists(buildDir)) System.IO.Directory.Delete(buildDir, true);\nSystem.IO.Directory.CreateDirectory(buildDir);\n\nstring exePath = buildDir + \"/FightForLife.exe\";\nvar scenes = new System.Collections.Generic.List<string>();\nforeach (var s in UnityEditor.EditorBuildSettings.scenes) if (s.enabled) scenes.Add(s.path);\nvar opts = new UnityEditor.BuildPlayerOptions();\nopts.scenes = scenes.ToArray();\nopts.locationPathName = exePath;\nopts.target = UnityEditor.BuildTarget.StandaloneWindows64;\nopts.targetGroup = UnityEditor.BuildTargetGroup.Standalone;\nopts.options = UnityEditor.BuildOptions.CleanBuildCache;\nvar report = UnityEditor.BuildPipeline.BuildPlayer(opts);\nreturn \"result=\"+report.summary.result+\" errors=\"+report.summary.totalErrors;","safety_checks":false,"compiler":"auto"}}
