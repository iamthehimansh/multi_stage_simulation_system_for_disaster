{"ts":"2026-04-11T18:05:10.919Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":2499,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// 1. Configure Swimming.fbx import settings - set to Humanoid rig\nstring swimPath = \"Assets/_FightForLife/Animations/Player/Swimming.fbx\";\nvar importer = UnityEditor.AssetImporter.GetAtPath(swimPath) as UnityEditor.ModelImporter;\nif (importer != null) {\n    importer.animationType = UnityEditor.ModelImporterAnimationType.Human;\n    // Copy avatar from Walking.fbx\n    var walkingImporter = UnityEditor.AssetImporter.GetAtPath(\"Assets/_FightForLife/Models/Player/Walking.fbx\") as UnityEditor.ModelImporter;\n    if (walkingImporter != null) {\n        importer.sourceAvatar = walkingImporter.sourceAvatar;\n    }\n    importer.SaveAndReimport();\n    sb.AppendLine(\"Swimming.fbx set to Humanoid rig\");\n}\n\n// 2. Get the animation clip from Swimming.fbx\nvar swimClip = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEngine.AnimationClip>(swimPath);\n// FBX files can contain multiple sub-assets; find the actual clip\nvar allAssets = UnityEditor.AssetDatabase.LoadAllAssetsAtPath(swimPath);\nUnityEngine.AnimationClip actualClip = null;\nforeach (var a in allAssets) {\n    if (a is UnityEngine.AnimationClip && !a.name.StartsWith(\"__\")) {\n        actualClip = (UnityEngine.AnimationClip)a;\n        sb.AppendLine(\"Found clip: \" + actualClip.name + \" (length=\" + actualClip.length + \"s)\");\n        break;\n    }\n}\n\n// 3. Add IsSwimming parameter to PlayerAnimator\nvar controller = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEditor.Animations.AnimatorController>(\n    \"Assets/_FightForLife/Animations/PlayerAnimator.controller\");\nif (controller != null) {\n    // Check if IsSwimming already exists\n    bool hasSwimParam = false;\n    foreach (var p in controller.parameters) {\n        if (p.name == \"IsSwimming\") { hasSwimParam = true; break; }\n    }\n    if (!hasSwimParam) {\n        controller.AddParameter(\"IsSwimming\", UnityEngine.AnimatorControllerParameterType.Bool);\n        sb.AppendLine(\"Added IsSwimming parameter\");\n    }\n    \n    // Add Swimming state\n    var baseLayer = controller.layers[0];\n    var sm = baseLayer.stateMachine;\n    \n    // Check if Swimming state already exists\n    bool hasSwimState = false;\n    foreach (var s in sm.states) {\n        if (s.state.name == \"Swimming\") { hasSwimState = true; break; }\n    }\n    \n    if (!hasSwimState && actualClip != null) {\n        var swimState = sm.AddState(\"Swimming\", new UnityEngine.Vector3(400, 200, 0));\n        swimState.motion = actualClip;\n        swimState.speed = 1f;\n        \n        // Make the clip loop\n        var clipSettings = UnityEditor.AnimationUtility.GetAnimationClipSettings(actualClip);\n        clipSettings.loopTime = true;\n        UnityEditor.AnimationUtility.SetAnimationClipSettings(actualClip, clipSettings);\n        \n        // Add transitions from any state -> Swimming when IsSwimming=true\n        var anyToSwim = sm.AddAnyStateTransition(swimState);\n        anyToSwim.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsSwimming\");\n        anyToSwim.duration = 0.15f;\n        anyToSwim.hasExitTime = false;\n        \n        // Add transition from Swimming -> Locomotion when IsSwimming=false\n        var locomotionState = sm.states[0].state; // Locomotion is first state\n        var swimToLoco = swimState.AddTransition(locomotionState);\n        swimToLoco.AddCondition(UnityEditor.Animations.AnimatorConditionMode.IfNot, 0, \"IsSwimming\");\n        swimToLoco.duration = 0.2f;\n        swimToLoco.hasExitTime = false;\n        \n        sb.AppendLine(\"Added Swimming state with transitions\");\n    }\n    \n    UnityEditor.EditorUtility.SetDirty(controller);\n    UnityEditor.AssetDatabase.SaveAssets();\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
