{"ts":"2026-04-11T19:27:33.084Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":943,"action":"execute","params":{"action":"execute","code":"\nvar controller = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEditor.Animations.AnimatorController>(\n    \"Assets/_FightForLife/Animations/PlayerAnimator.controller\");\nvar sm = controller.layers[0].stateMachine;\n\n// NUKE all AnyState transitions - they cause conflicts\nvar anyTransitions = sm.anyStateTransitions;\nfor (int i = anyTransitions.Length - 1; i >= 0; i--) {\n    sm.RemoveAnyStateTransition(anyTransitions[i]);\n}\n\n// Find states\nUnityEditor.Animations.AnimatorState locomotion = null, crouch = null, jump = null, swimming = null;\nforeach (var s in sm.states) {\n    if (s.state.name == \"Locomotion\") locomotion = s.state;\n    if (s.state.name == \"Crouch\") crouch = s.state;\n    if (s.state.name == \"Jump\") jump = s.state;\n    if (s.state.name == \"Swimming\") swimming = s.state;\n}\n\n// Clear ALL existing transitions from each state\nforeach (var s in sm.states) {\n    var trans = s.state.transitions;\n    for (int i = trans.Length - 1; i >= 0; i--)\n        s.state.RemoveTransition(trans[i]);\n}\n\n// Build clean transitions:\n// Locomotion -> Swimming (IsSwimming=true)\nvar t1 = locomotion.AddTransition(swimming);\nt1.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsSwimming\");\nt1.duration = 0.15f;\nt1.hasExitTime = false;\n\n// Locomotion -> Crouch (IsCrouching=true)\nvar t2 = locomotion.AddTransition(crouch);\nt2.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsCrouching\");\nt2.duration = 0.15f;\nt2.hasExitTime = false;\n\n// Locomotion -> Jump (IsGrounded=false AND IsSwimming=false)\nvar t3 = locomotion.AddTransition(jump);\nt3.AddCondition(UnityEditor.Animations.AnimatorConditionMode.IfNot, 0, \"IsGrounded\");\nt3.AddCondition(UnityEditor.Animations.AnimatorConditionMode.IfNot, 0, \"IsSwimming\");\nt3.duration = 0.1f;\nt3.hasExitTime = false;\n\n// Swimming -> Locomotion (IsSwimming=false)\nvar t4 = swimming.AddTransition(locomotion);\nt4.AddCondition(UnityEditor.Animations.AnimatorConditionMode.IfNot, 0, \"IsSwimming\");\nt4.duration = 0.2f;\nt4.hasExitTime = false;\n\n// Crouch -> Locomotion (IsCrouching=false)\nvar t5 = crouch.AddTransition(locomotion);\nt5.AddCondition(UnityEditor.Animations.AnimatorConditionMode.IfNot, 0, \"IsCrouching\");\nt5.duration = 0.15f;\nt5.hasExitTime = false;\n\n// Jump -> Locomotion (IsGrounded=true)\nvar t6 = jump.AddTransition(locomotion);\nt6.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsGrounded\");\nt6.duration = 0.15f;\nt6.hasExitTime = false;\n\n// Jump -> Swimming (IsSwimming=true) - in case player jumps into water\nvar t7 = jump.AddTransition(swimming);\nt7.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsSwimming\");\nt7.duration = 0.15f;\nt7.hasExitTime = false;\n\n// Crouch -> Swimming (IsSwimming=true)\nvar t8 = crouch.AddTransition(swimming);\nt8.AddCondition(UnityEditor.Animations.AnimatorConditionMode.If, 0, \"IsSwimming\");\nt8.duration = 0.15f;\nt8.hasExitTime = false;\n\nUnityEditor.EditorUtility.SetDirty(controller);\nUnityEditor.AssetDatabase.SaveAssets();\nUnityEditor.SceneManagement.EditorSceneManager.SaveScene(\n    UnityEngine.SceneManagement.SceneManager.GetActiveScene());\n\nreturn \"Rebuilt all animator transitions cleanly. No more AnyState conflicts.\";\n","safety_checks":true,"compiler":"auto"}}
