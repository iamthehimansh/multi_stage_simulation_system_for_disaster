{"ts":"2026-04-15T06:34:18.948Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1268,"action":"execute","params":{"action":"execute","code":"// Check which GameObjects actually have missing MonoBehaviours and try proper removal\nvar scene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\nint totalRemoved = 0;\nSystem.Action<UnityEngine.Transform> walk = null;\nwalk = (t) => {\n    int n = UnityEditor.GameObjectUtility.GetMonoBehavioursWithMissingScriptCount(t.gameObject);\n    if (n > 0) {\n        int r = UnityEditor.GameObjectUtility.RemoveMonoBehavioursWithMissingScript(t.gameObject);\n        totalRemoved += r;\n    }\n    foreach (UnityEngine.Transform c in t) walk(c);\n};\nforeach (var r in scene.GetRootGameObjects()) walk(r.transform);\nif (totalRemoved > 0) {\n    UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scene);\n    UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scene);\n}\nreturn \"removed=\"+totalRemoved;","safety_checks":true,"compiler":"auto"}}
