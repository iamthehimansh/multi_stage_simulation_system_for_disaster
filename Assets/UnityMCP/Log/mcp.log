{"ts":"2026-04-07T09:23:35.147Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":557,"action":"execute","params":{"action":"execute","code":"\n// Check compilation\nvar scripts = new string[] { \"GameHUD\", \"PauseMenu\", \"GameOverScreen\", \"MainMenuController\" };\nvar result = \"\";\nforeach (var name in scripts)\n{\n    var ms = AssetDatabase.LoadAssetAtPath<MonoScript>($\"Assets/_FightForLife/Scripts/UI/{name}.cs\");\n    if (ms != null)\n    {\n        var cls = ms.GetClass();\n        result += $\"{name}: {(cls != null ? \"OK\" : \"BROKEN\")}\\n\";\n    }\n}\nreturn result;\n","safety_checks":true,"compiler":"auto"}}
