{"ts":"2026-04-11T17:55:31.969Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":593,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// 1. GameplayUI\nvar gameplayUI = UnityEngine.GameObject.Find(\"GameplayUI\");\nif (gameplayUI != null) {\n    sb.AppendLine(\"=== GameplayUI ===\");\n    sb.AppendLine(\"Parent: \" + (gameplayUI.transform.parent != null ? gameplayUI.transform.parent.name : \"ROOT\"));\n    foreach (var c in gameplayUI.GetComponents<UnityEngine.Component>())\n        if (c != null) sb.AppendLine(\"  \" + c.GetType().FullName + \" enabled=\" + (c is UnityEngine.Behaviour ? ((UnityEngine.Behaviour)c).enabled.ToString() : \"n/a\"));\n}\n\n// 2. MissionZone details\nsb.AppendLine(\"\\n=== MissionZones ===\");\nvar mzType = typeof(FightForLife.Missions.MissionZone);\nvar zones = UnityEngine.Object.FindObjectsOfType(mzType, true);\nforeach (UnityEngine.MonoBehaviour z in zones) {\n    var so = new UnityEditor.SerializedObject(z);\n    sb.AppendLine(\"  \" + z.gameObject.name + \" pos=\" + z.transform.position);\n    var iter = so.GetIterator();\n    iter.Next(true);\n    while (iter.NextVisible(false)) {\n        if (iter.name == \"m_Script\") continue;\n        string val = \"\";\n        if (iter.propertyType == UnityEditor.SerializedPropertyType.String) val = iter.stringValue;\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Integer) val = iter.intValue.ToString();\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Float) val = iter.floatValue.ToString(\"F2\");\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Boolean) val = iter.boolValue.ToString();\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Enum) val = \"enum:\" + iter.enumValueIndex;\n        else val = iter.propertyType.ToString();\n        sb.AppendLine(\"    \" + iter.name + \"=\" + val);\n    }\n}\n\n// 3. MissionInteractable details  \nsb.AppendLine(\"\\n=== MissionInteractables ===\");\nvar miType = typeof(FightForLife.Missions.MissionInteractable);\nvar mis = UnityEngine.Object.FindObjectsOfType(miType, true);\nforeach (UnityEngine.MonoBehaviour mi in mis) {\n    var so = new UnityEditor.SerializedObject(mi);\n    sb.AppendLine(\"  \" + mi.gameObject.name + \" pos=\" + mi.transform.position);\n    var iter = so.GetIterator();\n    iter.Next(true);\n    while (iter.NextVisible(false)) {\n        if (iter.name == \"m_Script\") continue;\n        string val = \"\";\n        if (iter.propertyType == UnityEditor.SerializedPropertyType.String) val = iter.stringValue;\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Integer) val = iter.intValue.ToString();\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Float) val = iter.floatValue.ToString(\"F2\");\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Boolean) val = iter.boolValue.ToString();\n        else val = iter.propertyType.ToString();\n        sb.AppendLine(\"    \" + iter.name + \"=\" + val);\n    }\n}\n\n// 4. BellInteractable details\nsb.AppendLine(\"\\n=== BellInteractable ===\");\nvar bell = UnityEngine.Object.FindObjectOfType<FightForLife.Missions.BellInteractable>(true);\nif (bell != null) {\n    var so = new UnityEditor.SerializedObject(bell);\n    sb.AppendLine(\"  \" + bell.gameObject.name + \" pos=\" + bell.transform.position);\n    var iter = so.GetIterator();\n    iter.Next(true);\n    while (iter.NextVisible(false)) {\n        if (iter.name == \"m_Script\") continue;\n        string val = \"\";\n        if (iter.propertyType == UnityEditor.SerializedPropertyType.String) val = iter.stringValue;\n        else if (iter.propertyType == UnityEditor.SerializedPropertyType.Float) val = iter.floatValue.ToString(\"F2\");\n        else val = iter.propertyType.ToString();\n        sb.AppendLine(\"    \" + iter.name + \"=\" + val);\n    }\n    // Collider\n    var col = bell.GetComponent<UnityEngine.SphereCollider>();\n    if (col != null) sb.AppendLine(\"    SphereCollider: r=\" + col.radius + \" trigger=\" + col.isTrigger + \" center=\" + col.center);\n}\n\n// 5. FloodManager config\nvar fm = UnityEngine.Object.FindObjectOfType<FightForLife.Disaster.FloodManager>(true);\nif (fm != null) {\n    var so = new UnityEditor.SerializedObject(fm);\n    var cfg = so.FindProperty(\"config\").objectReferenceValue as FightForLife.Disaster.FloodConfig;\n    sb.AppendLine(\"\\n=== FloodConfig ===\");\n    if (cfg != null) {\n        sb.AppendLine(\"  initial=\" + cfg.initialWaterLevel + \" peak=\" + cfg.peakWaterLevel);\n        sb.AppendLine(\"  phase1Dur=\" + cfg.phase1Duration + \" phase2Dur=\" + cfg.phase2Duration + \" phase3Dur=\" + cfg.phase3Duration);\n        sb.AppendLine(\"  phase1Rise=\" + cfg.phase1RiseRate + \" phase2Rise=\" + cfg.phase2RiseRate + \" surgeRise=\" + cfg.surgeRiseRate);\n    }\n    sb.AppendLine(\"  waterPlane=\" + ((UnityEngine.Component)so.FindProperty(\"waterPlane\").objectReferenceValue).gameObject.name);\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
