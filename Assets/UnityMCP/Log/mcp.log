{"ts":"2026-04-11T18:51:25.487Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1212,"action":"execute","params":{"action":"execute","code":"\n// Check runtime state - we're in play mode\nvar sb = new System.Text.StringBuilder();\n\nvar player = UnityEngine.GameObject.Find(\"Player\");\nif (player != null) {\n    var pc = player.GetComponent<FightForLife.Player.PlayerController>();\n    var ph = player.GetComponent<FightForLife.Player.PlayerHealth>();\n    sb.AppendLine(\"Player Y: \" + player.transform.position.y);\n    if (pc != null) {\n        sb.AppendLine(\"State: \" + pc.CurrentState);\n        sb.AppendLine(\"WaterDepth: \" + pc.WaterDepth);\n        sb.AppendLine(\"IsSwimming: \" + pc.IsSwimming);\n        sb.AppendLine(\"IsWading: \" + pc.IsWading);\n        sb.AppendLine(\"IsDiving: \" + pc.IsDiving);\n        sb.AppendLine(\"CurrentSpeed: \" + pc.CurrentSpeed);\n    }\n}\n\nvar fm = FightForLife.Disaster.FloodManager.Instance;\nif (fm != null) {\n    sb.AppendLine(\"\\nFloodManager:\");\n    sb.AppendLine(\"  WaterLevel: \" + fm.WaterLevel);\n    sb.AppendLine(\"  Phase: \" + fm.CurrentPhase);\n    sb.AppendLine(\"  ElapsedTime: \" + fm.ElapsedTime);\n} else {\n    sb.AppendLine(\"\\nFloodManager.Instance is NULL!\");\n}\n\n// Check animator\nvar anim = player != null ? player.GetComponentInChildren<UnityEngine.Animator>() : null;\nif (anim != null) {\n    sb.AppendLine(\"\\nAnimator:\");\n    sb.AppendLine(\"  IsSwimming param: \" + anim.GetBool(\"IsSwimming\"));\n    sb.AppendLine(\"  Speed param: \" + anim.GetFloat(\"Speed\"));\n    sb.AppendLine(\"  Current state: \" + anim.GetCurrentAnimatorStateInfo(0).IsName(\"Swimming\"));\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
