{"ts":"2026-04-15T07:09:46.212Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":3860,"action":"execute","params":{"action":"execute","code":"// Check PlayerSettings preloaded assets - null entries cause level corruption\nvar preloaded = UnityEditor.PlayerSettings.GetPreloadedAssets();\nstring s = \"preloadedCount=\"+preloaded.Length+\"\\n\";\nint nullCount = 0;\nfor (int i = 0; i < preloaded.Length; i++) {\n    if (preloaded[i] == null) { nullCount++; s += \"  \"+i+\": NULL\\n\"; }\n    else s += \"  \"+i+\": \"+preloaded[i].name+\" (\"+preloaded[i].GetType().Name+\")\\n\";\n}\ns += \"nullCount=\"+nullCount+\"\\n\";\n// Remove nulls if any\nif (nullCount > 0) {\n    var cleaned = new System.Collections.Generic.List<UnityEngine.Object>();\n    foreach (var p in preloaded) if (p != null) cleaned.Add(p);\n    UnityEditor.PlayerSettings.SetPreloadedAssets(cleaned.ToArray());\n    UnityEditor.AssetDatabase.SaveAssets();\n    s += \"REMOVED \"+nullCount+\" null preloaded assets\\n\";\n}\n// Also check Resources folder contents (anything in Resources gets baked into globalgamemanagers)\nvar resGuids = UnityEditor.AssetDatabase.FindAssets(\"\", new[]{\"Assets/Resources\"});\ns += \"Resources assetCount=\"+resGuids.Length;\nreturn s;","safety_checks":true,"compiler":"auto"}}
