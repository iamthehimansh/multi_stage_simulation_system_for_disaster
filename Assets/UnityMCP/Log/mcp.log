{"ts":"2026-04-15T08:45:13.482Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":943,"action":"execute","params":{"action":"execute","code":"// Check current API level then force NET_Standard_2_0 (matches the existing layout)\nvar apiLevel = UnityEditor.PlayerSettings.GetApiCompatibilityLevel(UnityEditor.BuildTargetGroup.Standalone);\nvar backend = UnityEditor.PlayerSettings.GetScriptingBackend(UnityEditor.BuildTargetGroup.Standalone);\nstring before = \"before: api=\"+apiLevel+\" backend=\"+backend;\n\n// Set to NET Standard 2.1 (which is NET_Standard_2_0 in Unity 2022 enum naming)\nUnityEditor.PlayerSettings.SetApiCompatibilityLevel(\n    UnityEditor.BuildTargetGroup.Standalone,\n    UnityEditor.ApiCompatibilityLevel.NET_Standard_2_0);\nUnityEditor.AssetDatabase.SaveAssets();\n\nvar apiLevelAfter = UnityEditor.PlayerSettings.GetApiCompatibilityLevel(UnityEditor.BuildTargetGroup.Standalone);\nreturn before+\" | after api=\"+apiLevelAfter;","safety_checks":false,"compiler":"auto"}}
