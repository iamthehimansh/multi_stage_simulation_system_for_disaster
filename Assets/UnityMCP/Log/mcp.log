{"ts":"2026-04-11T17:57:41.997Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":2327,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// Fix duplicates - remove extra MissionZone components\nvar allZones = UnityEngine.Object.FindObjectsOfType<FightForLife.Missions.MissionZone>(true);\nvar seen = new System.Collections.Generic.HashSet<string>();\nforeach (var z in allZones) {\n    string key = z.gameObject.name;\n    if (seen.Contains(key)) {\n        UnityEngine.Object.DestroyImmediate(z);\n        sb.AppendLine(\"Removed duplicate MissionZone from \" + key);\n    } else {\n        seen.Add(key);\n    }\n}\n\n// Save\nUnityEditor.SceneManagement.EditorSceneManager.SaveScene(\n    UnityEngine.SceneManagement.SceneManager.GetActiveScene());\nsb.AppendLine(\"Scene saved.\");\n\n// Recount\nvar remaining = UnityEngine.Object.FindObjectsOfType<FightForLife.Missions.MissionZone>(true);\nsb.AppendLine(\"MissionZones remaining: \" + remaining.Length);\nforeach (var z in remaining) {\n    var so = new UnityEditor.SerializedObject(z);\n    var mid = so.FindProperty(\"missionId\");\n    var oid = so.FindProperty(\"objectiveId\");\n    sb.AppendLine(\"  \" + z.gameObject.name + \" -> \" + (mid != null ? mid.stringValue : \"?\") + \"/\" + (oid != null ? oid.stringValue : \"?\"));\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
