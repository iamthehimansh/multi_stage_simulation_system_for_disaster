{"ts":"2026-04-07T09:19:44.016Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":531,"action":"execute","params":{"action":"execute","code":"\n// Check script compilation status\nvar allScripts = Resources.FindObjectsOfTypeAll<MonoScript>();\nvar result = \"\";\nint broken = 0;\n\nforeach (var ms in allScripts)\n{\n    string name = ms.name;\n    if (name == \"GameHUD\" || name == \"PauseMenu\" || name == \"GameOverScreen\" || \n        name == \"MainMenuController\" || name == \"MissionFlowController\" ||\n        name == \"BellInteractable\" || name == \"MissionZone\" || name == \"MissionInteractable\")\n    {\n        var cls = ms.GetClass();\n        bool ok = cls != null;\n        result += $\"{name}: {(ok ? \"OK (\" + cls.FullName + \")\" : \"BROKEN (compile error)\")}\\n\";\n        if (!ok) broken++;\n    }\n}\n\nresult += $\"\\nBroken scripts: {broken}\";\nreturn result;\n","safety_checks":true,"compiler":"auto"}}
