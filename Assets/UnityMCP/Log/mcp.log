{"ts":"2026-04-11T16:22:49.386Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":646,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\nvar scene = UnityEngine.SceneManagement.SceneManager.GetActiveScene();\nsb.AppendLine($\"=== FINAL VERIFICATION ===\");\nsb.AppendLine($\"Scene: {scene.name} ({scene.path})\");\nsb.AppendLine($\"Root objects: {scene.rootCount}\");\n\nsb.AppendLine($\"\\n--- PLAYER ---\");\nvar player = UnityEngine.GameObject.Find(\"Player\");\nif (player != null) {\n    var smr = player.GetComponentInChildren<UnityEngine.SkinnedMeshRenderer>();\n    sb.AppendLine($\"  Real 3D model: {smr != null} ({player.transform.childCount} children including mesh parts)\");\n    sb.AppendLine($\"  Animator: {player.GetComponentInChildren<UnityEngine.Animator>()?.runtimeAnimatorController?.name ?? \"NONE\"}\");\n    sb.AppendLine($\"  All scripts: CC={player.GetComponent<UnityEngine.CharacterController>() != null}, \" +\n        $\"PC={player.GetComponent<FightForLife.Player.PlayerController>() != null}, \" +\n        $\"PH={player.GetComponent<FightForLife.Player.PlayerHealth>() != null}, \" +\n        $\"IS={player.GetComponent<FightForLife.Player.InteractionSystem>() != null}, \" +\n        $\"PI={player.GetComponent<FightForLife.Player.PlayerInventory>() != null}, \" +\n        $\"PAC={player.GetComponent<FightForLife.Player.PlayerAnimationController>() != null}\");\n}\n\nsb.AppendLine($\"\\n--- NPC SPAWNER ---\");\nvar spawner = UnityEngine.Object.FindObjectOfType<FightForLife.NPC.NPCSpawner>();\nif (spawner != null) {\n    var sso = new UnityEditor.SerializedObject(spawner);\n    sb.AppendLine($\"  Base prefab: {sso.FindProperty(\"npcPrefab\")?.objectReferenceValue?.name ?? \"NULL\"}\");\n    sb.AppendLine($\"  Variant count: {sso.FindProperty(\"npcPrefabVariants\")?.arraySize ?? 0}\");\n    sb.AppendLine($\"  Total NPCs to spawn: {sso.FindProperty(\"totalNPCs\")?.intValue ?? 0}\");\n    sb.AppendLine($\"  Spawn points: {sso.FindProperty(\"spawnPoints\")?.arraySize ?? 0}\");\n}\n\nsb.AppendLine($\"\\n--- HUD ---\");\nsb.AppendLine($\"  Canvases in scene: {UnityEngine.Object.FindObjectsOfType<UnityEngine.Canvas>(true).Length}\");\nsb.AppendLine($\"  (GameHUD.cs auto-creates HUD at runtime via [RuntimeInitializeOnLoadMethod])\");\nsb.AppendLine($\"  EventSystem: {UnityEngine.Object.FindObjectOfType<UnityEngine.EventSystems.EventSystem>() != null}\");\n\nsb.AppendLine($\"\\n--- FLOOD SYSTEM ---\");\nvar fm = UnityEngine.Object.FindObjectOfType<FightForLife.Disaster.FloodManager>();\nif (fm != null) {\n    var fmSO = new UnityEditor.SerializedObject(fm);\n    sb.AppendLine($\"  Config: {fmSO.FindProperty(\"config\")?.objectReferenceValue?.name ?? \"NULL\"}\");\n    sb.AppendLine($\"  WaterPlane: {((UnityEngine.Component)fmSO.FindProperty(\"waterPlane\")?.objectReferenceValue)?.gameObject?.name ?? \"NULL\"}\");\n}\n\nsb.AppendLine($\"\\n--- MISSIONS ---\");\nsb.AppendLine($\"  MissionManager: {UnityEngine.Object.FindObjectOfType<FightForLife.Core.MissionManager>() != null}\");\nsb.AppendLine($\"  MissionFlowController: {UnityEngine.Object.FindObjectOfType<FightForLife.Missions.MissionFlowController>() != null}\");\nvar bell = UnityEngine.GameObject.Find(\"TempleBellPosition\");\nsb.AppendLine($\"  Temple Bell: {bell != null} (BellInteractable: {bell?.GetComponent<FightForLife.Missions.BellInteractable>() != null})\");\nvar extract = UnityEngine.GameObject.Find(\"ExtractionPoint\");\nsb.AppendLine($\"  Extraction: {extract != null}\");\n\nsb.AppendLine($\"\\n--- RESCUE/CHECKPOINTS ---\");\nsb.AppendLine($\"  Rescue zones: {UnityEngine.Object.FindObjectsOfType<FightForLife.NPC.RescueZone>(true).Length}\");\nsb.AppendLine($\"  Checkpoints: {UnityEngine.Object.FindObjectsOfType<FightForLife.Core.Checkpoint>(true).Length}\");\n\nsb.AppendLine($\"\\n--- CAMERA ---\");\nvar cam = UnityEngine.Object.FindObjectOfType<FightForLife.Camera.ThirdPersonCamera>();\nif (cam != null) {\n    var camSO = new UnityEditor.SerializedObject(cam);\n    sb.AppendLine($\"  Target: {((UnityEngine.Object)camSO.FindProperty(\"target\")?.objectReferenceValue)?.name ?? \"NULL\"}\");\n}\n\nsb.AppendLine($\"\\n--- TRAINS ---\");\nvar trains = UnityEngine.GameObject.Find(\"--- TRAINS (Water Sources) ---\");\nsb.AppendLine($\"  Train parent: {trains != null} (children: {trains?.transform.childCount ?? 0})\");\n\nsb.AppendLine($\"\\nNavMesh: {UnityEngine.AI.NavMesh.CalculateTriangulation().vertices.Length} vertices\");\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
