{"ts":"2026-04-11T17:57:14.670Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":529,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\nvar bf = System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance;\nvar miType = typeof(FightForLife.Missions.MissionInteractable);\nvar shader = UnityEngine.Shader.Find(\"Universal Render Pipeline/Lit\");\n\n// ======== STEP 4: Create FenceGates (VS02 animal rescue) ========\n// Place near barn area (588, 45, 512-515)\nfor (int i = 0; i < 3; i++) {\n    var gate = UnityEngine.GameObject.CreatePrimitive(UnityEngine.PrimitiveType.Cube);\n    gate.name = \"FenceGate_\" + i;\n    gate.transform.position = new UnityEngine.Vector3(580f + i * 8f, 36f, 530f);\n    gate.transform.localScale = new UnityEngine.Vector3(0.3f, 1.5f, 3f);\n    var gateMat = new UnityEngine.Material(shader);\n    gateMat.color = new UnityEngine.Color(0.5f, 0.35f, 0.15f);\n    gate.GetComponent<UnityEngine.Renderer>().material = gateMat;\n    \n    var col = gate.GetComponent<UnityEngine.BoxCollider>();\n    col.isTrigger = false; // Solid gate\n    \n    var mi = gate.AddComponent<FightForLife.Missions.MissionInteractable>();\n    miType.GetField(\"promptText\", bf).SetValue(mi, \"Hold E - Open Gate\");\n    miType.GetField(\"holdTime\", bf).SetValue(mi, 1.5f);\n    miType.GetField(\"singleUse\", bf).SetValue(mi, true);\n    miType.GetField(\"missionId\", bf).SetValue(mi, \"VS02\");\n    miType.GetField(\"objectiveId\", bf).SetValue(mi, \"open_gates\");\n    miType.GetField(\"disableOnUse\", bf).SetValue(mi, true);\n    sb.AppendLine(\"Created FenceGate_\" + i);\n}\n\n// ======== STEP 5: Create RadioConsole (VS05 signal fire) ========\n// Near the radio tower (886, 34.82, 725)\nvar radio = UnityEngine.GameObject.CreatePrimitive(UnityEngine.PrimitiveType.Cube);\nradio.name = \"RadioConsole\";\nradio.transform.position = new UnityEngine.Vector3(886f, 35.5f, 730f);\nradio.transform.localScale = new UnityEngine.Vector3(1f, 1.2f, 0.6f);\nvar radioMat = new UnityEngine.Material(shader);\nradioMat.color = new UnityEngine.Color(0.3f, 0.3f, 0.35f);\nradio.GetComponent<UnityEngine.Renderer>().material = radioMat;\n\n// Put it inside a parent \"RadioTower\" to match Island_Flood structure\nvar radioParent = new UnityEngine.GameObject(\"RadioTower\");\nradioParent.transform.position = new UnityEngine.Vector3(886f, 35f, 725f);\nradio.transform.SetParent(radioParent.transform);\n\nvar rmi = radio.AddComponent<FightForLife.Missions.MissionInteractable>();\nmiType.GetField(\"promptText\", bf).SetValue(rmi, \"Hold E - Send SOS\");\nmiType.GetField(\"holdTime\", bf).SetValue(rmi, 3f);\nmiType.GetField(\"singleUse\", bf).SetValue(rmi, true);\nmiType.GetField(\"missionId\", bf).SetValue(rmi, \"VS05\");\nmiType.GetField(\"objectiveId\", bf).SetValue(rmi, \"send_sos\");\nmiType.GetField(\"disableOnUse\", bf).SetValue(rmi, true);\nsb.AppendLine(\"Created RadioConsole (VS05)\");\n\n// ======== STEP 6: Wire MissionFlowController to Temple_Bell ========\nvar mfc = UnityEngine.Object.FindObjectOfType<FightForLife.Missions.MissionFlowController>(true);\nif (mfc != null) {\n    var bell = UnityEngine.GameObject.Find(\"Temple_Bell\");\n    var extract = UnityEngine.GameObject.Find(\"ExtractionPoint\");\n    var mfcSO = new UnityEditor.SerializedObject(mfc);\n    if (bell != null) {\n        mfcSO.FindProperty(\"templeBellPosition\").objectReferenceValue = bell.transform;\n        sb.AppendLine(\"Wired MFC -> Temple_Bell\");\n    }\n    if (extract != null) {\n        mfcSO.FindProperty(\"extractionPosition\").objectReferenceValue = extract.transform;\n        sb.AppendLine(\"Wired MFC -> ExtractionPoint\");\n    }\n    mfcSO.ApplyModifiedProperties();\n}\n\n// ======== STEP 7: Ensure EventSystem exists ========\nvar es = UnityEngine.Object.FindObjectOfType<UnityEngine.EventSystems.EventSystem>(true);\nif (es == null) {\n    var esGO = new UnityEngine.GameObject(\"EventSystem\");\n    esGO.AddComponent<UnityEngine.EventSystems.EventSystem>();\n    esGO.AddComponent<UnityEngine.EventSystems.StandaloneInputModule>();\n    sb.AppendLine(\"Created EventSystem\");\n}\n\n// ======== STEP 8: Ensure GameManager is at ROOT for DontDestroyOnLoad ========\nvar gm = UnityEngine.Object.FindObjectOfType<FightForLife.Core.GameManager>(true);\nif (gm != null && gm.transform.parent != null) {\n    gm.transform.SetParent(null);\n    sb.AppendLine(\"Moved GameManager to root\");\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
