{"ts":"2026-04-15T06:34:02.909Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":3007,"action":"execute","params":{"action":"execute","code":"// Load Island_Flood without play mode, hunt for missing scripts\nvar openScene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\nstring originalPath = openScene.path;\nvar targetPath = \"Assets/_FightForLife/Scenes/Island_Flood.unity\";\nif (openScene.path != targetPath) {\n    UnityEditor.SceneManagement.EditorSceneManager.OpenScene(targetPath, UnityEditor.SceneManagement.OpenSceneMode.Single);\n}\nvar scene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\nint totalMissing = 0;\nint goWithMissing = 0;\nvar toClean = new System.Collections.Generic.List<UnityEngine.GameObject>();\nvar roots = scene.GetRootGameObjects();\nSystem.Action<UnityEngine.Transform> walk = null;\nwalk = (t) => {\n    var comps = t.GetComponents<UnityEngine.Component>();\n    int missingHere = 0;\n    foreach (var c in comps) if (c == null) missingHere++;\n    if (missingHere > 0) {\n        totalMissing += missingHere;\n        goWithMissing++;\n        toClean.Add(t.gameObject);\n    }\n    foreach (UnityEngine.Transform child in t) walk(child);\n};\nforeach (var r in roots) walk(r.transform);\n// Also remove missing scripts using GameObjectUtility\nint removed = 0;\nforeach (var go in toClean) {\n    removed += UnityEditor.GameObjectUtility.RemoveMonoBehavioursWithMissingScript(go);\n}\nif (removed > 0) {\n    UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scene);\n    UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scene);\n}\nreturn \"scene=\"+scene.path+\" goWithMissing=\"+goWithMissing+\" missingBefore=\"+totalMissing+\" removed=\"+removed;","safety_checks":true,"compiler":"auto"}}
