{"ts":"2026-04-15T06:35:41.697Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1701,"action":"execute","params":{"action":"execute","code":"// 1. Add URP/Unlit + URP/Lit to Always Included Shaders\nvar assets = UnityEditor.AssetDatabase.LoadAllAssetsAtPath(\"ProjectSettings/GraphicsSettings.asset\");\nvar so = new UnityEditor.SerializedObject(assets[0]);\nvar always = so.FindProperty(\"m_AlwaysIncludedShaders\");\nvar urpUnlit = UnityEngine.Shader.Find(\"Universal Render Pipeline/Unlit\");\nvar urpLit = UnityEngine.Shader.Find(\"Universal Render Pipeline/Lit\");\nbool hasUnlit = false, hasLit = false;\nfor (int i = 0; i < always.arraySize; i++) {\n    var el = always.GetArrayElementAtIndex(i).objectReferenceValue;\n    if (el == urpUnlit) hasUnlit = true;\n    if (el == urpLit) hasLit = true;\n}\nint added = 0;\nif (!hasUnlit && urpUnlit != null) { always.arraySize++; always.GetArrayElementAtIndex(always.arraySize-1).objectReferenceValue = urpUnlit; added++; }\nif (!hasLit && urpLit != null) { always.arraySize++; always.GetArrayElementAtIndex(always.arraySize-1).objectReferenceValue = urpLit; added++; }\nso.ApplyModifiedProperties();\nUnityEditor.AssetDatabase.SaveAssets();\n\n// 2. Wipe PlayerDataCache + build output\nstring projRoot = System.IO.Path.GetDirectoryName(UnityEngine.Application.dataPath);\nstring cache = projRoot + \"/Library/PlayerDataCache\";\nbool hadCache = System.IO.Directory.Exists(cache);\nif (hadCache) System.IO.Directory.Delete(cache, true);\nstring buildDir = \"H:/fight-for-life-unity/Builds/FightForLife_Win\";\nbool hadBuild = System.IO.Directory.Exists(buildDir);\nif (hadBuild) System.IO.Directory.Delete(buildDir, true);\nSystem.IO.Directory.CreateDirectory(buildDir);\nreturn \"addedShaders=\"+added+\" wipedCache=\"+hadCache+\" wipedBuild=\"+hadBuild;","safety_checks":false,"compiler":"auto"}}
