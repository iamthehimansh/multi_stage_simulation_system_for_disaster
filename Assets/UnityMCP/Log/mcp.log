{"ts":"2026-04-11T18:56:53.829Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1345,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\nsb.AppendLine(\"Playing: \" + UnityEditor.EditorApplication.isPlaying);\n\nvar player = UnityEngine.GameObject.Find(\"Player\");\nif (player != null) {\n    var pc = player.GetComponent<FightForLife.Player.PlayerController>();\n    if (pc != null) {\n        var pcSO = new UnityEditor.SerializedObject(pc);\n        sb.AppendLine(\"splashDepth=\" + pcSO.FindProperty(\"splashDepth\").floatValue);\n        sb.AppendLine(\"deepWadeDepth=\" + pcSO.FindProperty(\"deepWadeDepth\").floatValue);\n    }\n}\n\nvar fm = UnityEngine.Object.FindObjectOfType<FightForLife.Disaster.FloodManager>(true);\nif (fm != null) {\n    var fmSO = new UnityEditor.SerializedObject(fm);\n    var cfg = fmSO.FindProperty(\"config\").objectReferenceValue as FightForLife.Disaster.FloodConfig;\n    if (cfg != null) sb.AppendLine(\"FloodConfig initial=\" + cfg.initialWaterLevel);\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
