{"ts":"2026-04-15T07:16:27.391Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1691,"action":"execute","params":{"action":"execute","code":"// Delete the probe file\nSystem.IO.File.Delete(\"H:/fight-for-life-unity/Assets/_FightForLife/Scenes/Island_Flood_RESAVED.unity\");\nSystem.IO.File.Delete(\"H:/fight-for-life-unity/Assets/_FightForLife/Scenes/Island_Flood_RESAVED.unity.meta\");\nUnityEditor.EditorSettings.serializationMode = UnityEditor.SerializationMode.ForceText;\n\n// Open the binary scene\nvar src = UnityEditor.SceneManagement.EditorSceneManager.OpenScene(\n    \"Assets/_FightForLife/Scenes/Island_Flood.unity\",\n    UnityEditor.SceneManagement.OpenSceneMode.Single);\nvar rootsSrc = src.GetRootGameObjects();\nint rootCount = rootsSrc.Length;\n\n// Create a fresh text scene ADDITIVE so both are loaded, then move roots\nvar dst = UnityEditor.SceneManagement.EditorSceneManager.NewScene(\n    UnityEditor.SceneManagement.NewSceneSetup.EmptyScene,\n    UnityEditor.SceneManagement.NewSceneMode.Additive);\n\nint moved = 0;\nforeach (var go in rootsSrc) {\n    if (go == null) continue;\n    UnityEngine.SceneManagement.SceneManager.MoveGameObjectToScene(go, dst);\n    moved++;\n}\n\n// Save dst to a new path (should be text because it's a fresh scene)\nstring dstPath = \"Assets/_FightForLife/Scenes/Island_Flood_Fixed.unity\";\nbool ok = UnityEditor.SceneManagement.EditorSceneManager.SaveScene(dst, dstPath, false);\nvar fi = new System.IO.FileInfo(dstPath);\nbyte[] head = new byte[10];\nusing (var fs = System.IO.File.OpenRead(dstPath)) { fs.Read(head, 0, 10); }\nbool isText = head[0]=='%' && head[1]=='Y' && head[2]=='A' && head[3]=='M' && head[4]=='L';\nreturn \"rootsSrc=\"+rootCount+\" moved=\"+moved+\" saved=\"+ok+\" size=\"+fi.Length+\" isText=\"+isText;","safety_checks":false,"compiler":"auto"}}
