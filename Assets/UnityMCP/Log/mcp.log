{"ts":"2026-04-07T09:23:56.304Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":637,"action":"execute","params":{"action":"execute","code":"\n// Use MonoScript to get the actual types\nvar managers = GameObject.Find(\"--- MANAGERS ---\");\nvar uiGO = GameObject.Find(\"GameplayUI\");\nif (uiGO == null)\n{\n    uiGO = new GameObject(\"GameplayUI\");\n    uiGO.transform.SetParent(managers.transform);\n}\n\nvar result = \"\";\n\nvar hudScript = AssetDatabase.LoadAssetAtPath<MonoScript>(\"Assets/_FightForLife/Scripts/UI/GameHUD.cs\");\nvar pauseScript = AssetDatabase.LoadAssetAtPath<MonoScript>(\"Assets/_FightForLife/Scripts/UI/PauseMenu.cs\");\nvar goScript = AssetDatabase.LoadAssetAtPath<MonoScript>(\"Assets/_FightForLife/Scripts/UI/GameOverScreen.cs\");\n\nif (hudScript != null && hudScript.GetClass() != null)\n{\n    uiGO.AddComponent(hudScript.GetClass());\n    result += \"GameHUD added\\n\";\n}\nif (pauseScript != null && pauseScript.GetClass() != null)\n{\n    uiGO.AddComponent(pauseScript.GetClass());\n    result += \"PauseMenu added\\n\";\n}\nif (goScript != null && goScript.GetClass() != null)\n{\n    uiGO.AddComponent(goScript.GetClass());\n    result += \"GameOverScreen added\\n\";\n}\n\nUnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(\n    UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene());\nUnityEditor.SceneManagement.EditorSceneManager.SaveOpenScenes();\n\nreturn result + \"Scene saved!\";\n","safety_checks":true,"compiler":"auto"}}
