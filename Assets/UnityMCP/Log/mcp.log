{"ts":"2026-04-11T17:56:24.700Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1169,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\nvar bf = System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance;\n\n// ======== STEP 1: Create GameplayUI (exact copy from Island_Flood) ========\nvar managers = UnityEngine.GameObject.Find(\"--- MANAGERS ---\");\n\n// Delete any existing conflicting UI objects\nforeach (var name in new[] {\"GameplayUI\", \"GameHUD_Canvas\", \"PauseMenu_Canvas\", \"GameOver_Canvas\"}) {\n    var existing = UnityEngine.GameObject.Find(name);\n    if (existing != null) UnityEngine.Object.DestroyImmediate(existing);\n}\n\n// Create GameplayUI exactly like Island_Flood: one GO with all 3 scripts\nvar gameplayUI = new UnityEngine.GameObject(\"GameplayUI\");\ngameplayUI.transform.SetParent(managers.transform);\ngameplayUI.AddComponent<FightForLife.UI.GameHUD>();        // The self-contained procedural HUD\ngameplayUI.AddComponent<FightForLife.UI.PauseMenu>();      // ESC pause\ngameplayUI.AddComponent<FightForLife.UI.GameOverScreen>(); // Win/lose screen\nsb.AppendLine(\"Created GameplayUI with GameHUD + PauseMenu + GameOverScreen\");\n\n// ======== STEP 2: Fix TempleBellPosition -> proper Temple_Bell ========\n// Island_Flood uses \"Temple_Bell\" with SphereCollider r=5\nvar oldBell = UnityEngine.GameObject.Find(\"TempleBellPosition\");\nif (oldBell != null) {\n    // Update name to match Island_Flood\n    oldBell.name = \"Temple_Bell\";\n    \n    // Fix collider: Island_Flood uses r=5, center=(0,0,0)\n    var existingSphere = oldBell.GetComponent<UnityEngine.SphereCollider>();\n    if (existingSphere != null) {\n        existingSphere.radius = 5f;\n        existingSphere.center = UnityEngine.Vector3.zero;\n        existingSphere.isTrigger = true;\n    }\n    \n    // Fix BellInteractable holdTime\n    var bellComp = oldBell.GetComponent<FightForLife.Missions.BellInteractable>();\n    if (bellComp != null) {\n        var holdField = typeof(FightForLife.Missions.BellInteractable).GetField(\"holdTime\", bf);\n        if (holdField != null) holdField.SetValue(bellComp, 2f);\n    }\n    sb.AppendLine(\"Fixed Temple_Bell (r=5, holdTime=2)\");\n}\n\n// ======== STEP 3: Create MissionZones (exact copy from Island_Flood) ========\n\n// 3a. TempleReachZone - detect player reaching the temple\n// In Island_Flood: pos=(-375, 19.92, 755). Adapt to our temple at (218, 38, 755)\nvar templeReach = new UnityEngine.GameObject(\"TempleReachZone\");\ntempleReach.transform.position = new UnityEngine.Vector3(218f, 40f, 755f);\nvar trCol = templeReach.AddComponent<UnityEngine.BoxCollider>();\ntrCol.isTrigger = true;\ntrCol.size = new UnityEngine.Vector3(20f, 10f, 20f);\nvar trZone = templeReach.AddComponent<FightForLife.Missions.MissionZone>();\nvar mzType = typeof(FightForLife.Missions.MissionZone);\nmzType.GetField(\"missionId\", bf).SetValue(trZone, \"VM01\");\nmzType.GetField(\"objectiveId\", bf).SetValue(trZone, \"reach_temple\");\nmzType.GetField(\"detectPlayer\", bf).SetValue(trZone, true);\nmzType.GetField(\"detectFollowingNPCs\", bf).SetValue(trZone, false);\nmzType.GetField(\"oneShot\", bf).SetValue(trZone, true);\nsb.AppendLine(\"Created TempleReachZone (VM01/reach_temple)\");\n\n// 3b. RescueZone_VillageCenter - detect NPCs following player into village center\nvar villageRescue = new UnityEngine.GameObject(\"RescueZone_VillageCenter\");\nvillageRescue.transform.position = new UnityEngine.Vector3(500f, 37f, 500f);\nvar vrCol = villageRescue.AddComponent<UnityEngine.BoxCollider>();\nvrCol.isTrigger = true;\nvrCol.size = new UnityEngine.Vector3(40f, 10f, 40f);\nvar vrZone = villageRescue.AddComponent<FightForLife.Missions.MissionZone>();\nmzType.GetField(\"missionId\", bf).SetValue(vrZone, \"VM02\");\nmzType.GetField(\"objectiveId\", bf).SetValue(vrZone, \"rescue_families\");\nmzType.GetField(\"detectPlayer\", bf).SetValue(vrZone, false);\nmzType.GetField(\"detectFollowingNPCs\", bf).SetValue(vrZone, true);\nmzType.GetField(\"oneShot\", bf).SetValue(vrZone, false);\nsb.AppendLine(\"Created RescueZone_VillageCenter (VM02/rescue_families)\");\n\n// 3c. BridgeCrossZone - detect NPCs crossing the bridge\n// Our bridge is at (976, 52.6, 960)\nvar bridgeCross = new UnityEngine.GameObject(\"BridgeCrossZone\");\nbridgeCross.transform.position = new UnityEngine.Vector3(976f, 53f, 960f);\nvar bcCol = bridgeCross.AddComponent<UnityEngine.BoxCollider>();\nbcCol.isTrigger = true;\nbcCol.size = new UnityEngine.Vector3(20f, 10f, 20f);\nvar bcZone = bridgeCross.AddComponent<FightForLife.Missions.MissionZone>();\nmzType.GetField(\"missionId\", bf).SetValue(bcZone, \"VM03\");\nmzType.GetField(\"objectiveId\", bf).SetValue(bcZone, \"guide_across\");\nmzType.GetField(\"detectPlayer\", bf).SetValue(bcZone, false);\nmzType.GetField(\"detectFollowingNPCs\", bf).SetValue(bcZone, true);\nmzType.GetField(\"oneShot\", bf).SetValue(bcZone, false);\nsb.AppendLine(\"Created BridgeCrossZone (VM03/guide_across)\");\n\n// 3d. Fix ExtractionPoint - add MissionZone component\nvar extraction = UnityEngine.GameObject.Find(\"ExtractionPoint\");\nif (extraction != null) {\n    var existingMZ = extraction.GetComponent<FightForLife.Missions.MissionZone>();\n    if (existingMZ == null) {\n        var exZone = extraction.AddComponent<FightForLife.Missions.MissionZone>();\n        mzType.GetField(\"missionId\", bf).SetValue(exZone, \"VM05\");\n        mzType.GetField(\"objectiveId\", bf).SetValue(exZone, \"reach_extraction\");\n        mzType.GetField(\"detectPlayer\", bf).SetValue(exZone, true);\n        mzType.GetField(\"detectFollowingNPCs\", bf).SetValue(exZone, false);\n        mzType.GetField(\"oneShot\", bf).SetValue(exZone, true);\n        sb.AppendLine(\"Added MissionZone to ExtractionPoint (VM05/reach_extraction)\");\n    }\n}\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
