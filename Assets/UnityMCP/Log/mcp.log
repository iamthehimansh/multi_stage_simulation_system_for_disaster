{"ts":"2026-04-11T18:52:12.620Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":949,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// Fix FloodConfig - raise water levels to match terrain at Y=34.82\nvar configPath = \"Assets/_FightForLife/ScriptableObjects/IslandFloodConfig.asset\";\nvar config = UnityEditor.AssetDatabase.LoadAssetAtPath<FightForLife.Disaster.FloodConfig>(configPath);\n\nif (config != null) {\n    sb.AppendLine(\"OLD values:\");\n    sb.AppendLine(\"  initial=\" + config.initialWaterLevel + \" peak=\" + config.peakWaterLevel);\n    \n    // Terrain is at Y=34.82. Set water to start AT ground level\n    config.initialWaterLevel = 34f;     // Just below terrain - water visible from start\n    config.phase1WaterLevel = 35.5f;    // Ankle deep during warning\n    config.phase2WaterLevel = 37f;      // Waist deep during disaster\n    config.peakWaterLevel = 40f;        // Deep flooding\n    config.surgeAdditional = 2f;        // Surge to 42\n    \n    // Faster rise so gameplay feels urgent\n    config.phase1RiseRate = 0.5f;       // Warning: slow rise\n    config.phase2RiseRate = 1.2f;       // Disaster: fast rise\n    config.surgeRiseRate = 3f;          // Surge: very fast\n    config.phase3RiseRate = 0.1f;       // Escape: almost stable\n    \n    UnityEditor.EditorUtility.SetDirty(config);\n    UnityEditor.AssetDatabase.SaveAssets();\n    \n    sb.AppendLine(\"\\nNEW values:\");\n    sb.AppendLine(\"  initial=\" + config.initialWaterLevel + \" peak=\" + config.peakWaterLevel);\n    sb.AppendLine(\"  phase1Rise=\" + config.phase1RiseRate + \" phase2Rise=\" + config.phase2RiseRate);\n}\n\n// Also move the WaterPlane to match\nvar waterPlane = UnityEngine.GameObject.Find(\"WaterPlane\");\nif (waterPlane != null) {\n    waterPlane.transform.position = new UnityEngine.Vector3(\n        waterPlane.transform.position.x, 34f, waterPlane.transform.position.z);\n    sb.AppendLine(\"\\nWaterPlane moved to Y=34\");\n}\n\n// Save scene\nUnityEditor.SceneManagement.EditorSceneManager.SaveScene(\n    UnityEngine.SceneManagement.SceneManager.GetActiveScene());\nsb.AppendLine(\"Scene saved.\");\n\nreturn sb.ToString();\n","safety_checks":false,"compiler":"auto"}}
