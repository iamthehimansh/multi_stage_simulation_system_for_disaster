{"ts":"2026-04-11T18:57:23.673Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":646,"action":"execute","params":{"action":"execute","code":"\n// Lower the deepWadeDepth so swimming triggers earlier\nvar player = UnityEngine.GameObject.Find(\"Player\");\nvar pc = player.GetComponent<FightForLife.Player.PlayerController>();\nvar pcSO = new UnityEditor.SerializedObject(pc);\n\n// Change thresholds: swim at 0.5m depth instead of 1.2m\npcSO.FindProperty(\"splashDepth\").floatValue = 0.15f;       // Splash effects at 15cm\npcSO.FindProperty(\"shallowWadeDepth\").floatValue = 0.3f;   // Slow down at 30cm\npcSO.FindProperty(\"deepWadeDepth\").floatValue = 0.5f;      // Start SWIMMING at 50cm\npcSO.ApplyModifiedProperties();\n\nreturn \"Set deepWadeDepth=0.5 (was 1.2). Current WaterDepth=\" + pc.WaterDepth + \" -> should now be Swimming!\";\n","safety_checks":true,"compiler":"auto"}}
