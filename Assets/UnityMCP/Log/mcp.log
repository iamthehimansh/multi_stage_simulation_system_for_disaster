{"ts":"2026-04-15T07:05:14.136Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":2141,"action":"execute","params":{"action":"execute","code":"// For each scene, find the offending named GameObjects, unpack prefab instances\n// completely, then remove missing MonoBehaviours.\nvar offenderNames = new System.Collections.Generic.HashSet<string> {\n    \"Checkpoint_Village\",\"Checkpoint_Lighthouse\",\"Checkpoint_Temple\",\n    \"Item_Flashlight\",\"Item_Flashlight_02\",\n};\nstring[] scenePaths = {\n    \"Assets/_FightForLife/Scenes/Island_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/Island_flood_m.unity\",\n    \"Assets/_FightForLife/Scenes/Village_Flood.unity\",\n};\nstring report = \"\";\nforeach (var path in scenePaths) {\n    UnityEditor.SceneManagement.EditorSceneManager.OpenScene(path, UnityEditor.SceneManagement.OpenSceneMode.Single);\n    var scene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\n    var targets = new System.Collections.Generic.List<UnityEngine.GameObject>();\n    System.Action<UnityEngine.Transform> walk = null;\n    walk = (t) => {\n        if (offenderNames.Contains(t.gameObject.name)) targets.Add(t.gameObject);\n        for (int i = 0; i < t.childCount; i++) walk(t.GetChild(i));\n    };\n    foreach (var r in scene.GetRootGameObjects()) walk(r.transform);\n\n    int unpacked = 0, removed = 0;\n    foreach (var go in targets) {\n        // Find the outermost prefab instance root\n        var root = UnityEditor.PrefabUtility.GetOutermostPrefabInstanceRoot(go);\n        if (root != null) {\n            UnityEditor.PrefabUtility.UnpackPrefabInstance(root,\n                UnityEditor.PrefabUnpackMode.Completely,\n                UnityEditor.InteractionMode.AutomatedAction);\n            unpacked++;\n        }\n        // Now walk the GO and its children and remove missing MBs\n        System.Action<UnityEngine.Transform> clean = null;\n        clean = (t) => {\n            int r = UnityEditor.GameObjectUtility.RemoveMonoBehavioursWithMissingScript(t.gameObject);\n            if (r > 0) removed += r;\n            for (int i = 0; i < t.childCount; i++) clean(t.GetChild(i));\n        };\n        clean(go.transform);\n    }\n    if (removed > 0 || unpacked > 0) {\n        UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scene);\n        UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scene);\n    }\n    report += path+\" targets=\"+targets.Count+\" unpacked=\"+unpacked+\" removed=\"+removed+\"\\n\";\n}\nreturn report;","safety_checks":false,"compiler":"auto"}}
