{"ts":"2026-04-11T18:04:35.350Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":2380,"action":"execute","params":{"action":"execute","code":"\nvar sb = new System.Text.StringBuilder();\n\n// Check PlayerAnimator controller parameters and states\nvar controller = UnityEditor.AssetDatabase.LoadAssetAtPath<UnityEditor.Animations.AnimatorController>(\n    \"Assets/_FightForLife/Animations/PlayerAnimator.controller\");\nif (controller != null) {\n    sb.AppendLine(\"=== PlayerAnimator Parameters ===\");\n    foreach (var p in controller.parameters)\n        sb.AppendLine(\"  \" + p.name + \" (\" + p.type + \")\");\n    \n    sb.AppendLine(\"\\n=== Layers ===\");\n    foreach (var layer in controller.layers) {\n        sb.AppendLine(\"  Layer: \" + layer.name);\n        var sm = layer.stateMachine;\n        foreach (var state in sm.states) {\n            var motion = state.state.motion;\n            sb.AppendLine(\"    State: \" + state.state.name + \" -> \" + (motion != null ? motion.name : \"NULL\"));\n        }\n        // Sub-state machines\n        foreach (var sub in sm.stateMachines) {\n            sb.AppendLine(\"    SubSM: \" + sub.stateMachine.name);\n            foreach (var s in sub.stateMachine.states)\n                sb.AppendLine(\"      State: \" + s.state.name + \" -> \" + (s.state.motion != null ? s.state.motion.name : \"NULL\"));\n        }\n    }\n}\n\n// Check existing animation clips\nvar animGuids = UnityEditor.AssetDatabase.FindAssets(\"t:AnimationClip\", new[] {\"Assets/_FightForLife/Animations/Player\"});\nsb.AppendLine(\"\\n=== Animation Clips ===\");\nforeach (var g in animGuids) {\n    var path = UnityEditor.AssetDatabase.GUIDToAssetPath(g);\n    sb.AppendLine(\"  \" + path);\n}\n\n// Check if Swimming.fbx exists\nsb.AppendLine(\"\\n=== Swimming.fbx check ===\");\nsb.AppendLine(\"  Downloads: \" + System.IO.File.Exists(\"C:/Users/pc/Downloads/Swimming.fbx\"));\nsb.AppendLine(\"  Project: \" + System.IO.File.Exists(\"H:/fight-for-life-unity/Assets/_FightForLife/Animations/Player/Swimming.fbx\"));\n\nreturn sb.ToString();\n","safety_checks":true,"compiler":"auto"}}
