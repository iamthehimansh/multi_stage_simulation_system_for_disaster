{"ts":"2026-04-15T07:01:04.021Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":2369,"action":"execute","params":{"action":"execute","code":"// 1. Disable managed code stripping\nUnityEditor.PlayerSettings.SetManagedStrippingLevel(UnityEditor.BuildTargetGroup.Standalone, UnityEditor.ManagedStrippingLevel.Disabled);\n\n// 2. Disable mipmap streaming in Quality Settings (all levels)\nint qc = UnityEngine.QualitySettings.names.Length;\nint origLevel = UnityEngine.QualitySettings.GetQualityLevel();\nfor (int i = 0; i < qc; i++) {\n    UnityEngine.QualitySettings.SetQualityLevel(i, false);\n    UnityEngine.QualitySettings.streamingMipmapsActive = false;\n}\nUnityEngine.QualitySettings.SetQualityLevel(origLevel, false);\n\n// 3. Disable scripting runtime version to Mono (not IL2CPP) — we're already on Mono but double-check\nvar backend = UnityEditor.PlayerSettings.GetScriptingBackend(UnityEditor.BuildTargetGroup.Standalone);\n\n// 4. Wipe build output + player data cache\nstring projRoot = System.IO.Path.GetDirectoryName(UnityEngine.Application.dataPath);\nstring cache = projRoot + \"/Library/PlayerDataCache\";\nif (System.IO.Directory.Exists(cache)) System.IO.Directory.Delete(cache, true);\nstring buildDir = \"H:/fight-for-life-unity/Builds/FightForLife_Win\";\nif (System.IO.Directory.Exists(buildDir)) System.IO.Directory.Delete(buildDir, true);\nSystem.IO.Directory.CreateDirectory(buildDir);\n\nUnityEditor.AssetDatabase.SaveAssets();\nreturn \"strippingDisabled OK, mipStreamingOff OK, backend=\"+backend+\" cacheWiped OK\";","safety_checks":false,"compiler":"auto"}}
