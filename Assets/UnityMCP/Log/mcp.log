{"ts":"2026-04-15T07:07:49.986Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":3726,"action":"execute","params":{"action":"execute","code":"// Force-reserialize all gameplay scene + key asset dependencies.\nvar paths = new string[] {\n    \"Assets/_FightForLife/Scenes/MainMenu.unity\",\n    \"Assets/_FightForLife/Scenes/Island_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/Island_flood_m.unity\",\n    \"Assets/_FightForLife/Scenes/Island_flood_m/NavMesh.asset\",\n};\nUnityEditor.AssetDatabase.ForceReserializeAssets(paths,\n    UnityEditor.ForceReserializeAssetsOptions.ReserializeAssetsAndMetadata);\nUnityEditor.AssetDatabase.SaveAssets();\nUnityEditor.AssetDatabase.Refresh();\n\n// Also wipe PlayerDataCache and build output\nstring projRoot = System.IO.Path.GetDirectoryName(UnityEngine.Application.dataPath);\nstring cache = projRoot + \"/Library/PlayerDataCache\";\nbool wipedCache = false;\nif (System.IO.Directory.Exists(cache)) { System.IO.Directory.Delete(cache, true); wipedCache = true; }\nstring buildDir = \"H:/fight-for-life-unity/Builds/FightForLife_Win\";\nif (System.IO.Directory.Exists(buildDir)) System.IO.Directory.Delete(buildDir, true);\nSystem.IO.Directory.CreateDirectory(buildDir);\nreturn \"reserialize done, wipedCache=\"+wipedCache;","safety_checks":false,"compiler":"auto"}}
