{"ts":"2026-04-07T09:21:06.232Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":527,"action":"execute","params":{"action":"execute","code":"\n// Try to load each broken script to get specific error\nvar scripts = new string[] {\n    \"Assets/_FightForLife/Scripts/UI/GameHUD.cs\",\n    \"Assets/_FightForLife/Scripts/UI/PauseMenu.cs\",\n    \"Assets/_FightForLife/Scripts/UI/GameOverScreen.cs\"\n};\n\nvar result = \"\";\nforeach (var path in scripts)\n{\n    var script = AssetDatabase.LoadAssetAtPath<MonoScript>(path);\n    if (script != null)\n    {\n        var cls = script.GetClass();\n        result += $\"{path}: Class={(cls != null ? cls.FullName : \"NULL\")}\\n\";\n        \n        // Check the compile error message\n        if (cls == null)\n        {\n            // Read first few lines to check for syntax\n            string content = System.IO.File.ReadAllText(\"H:/fight-for-life-unity/\" + path);\n            // Check for common issues\n            if (content.Contains(\"using UnityEngine.InputSystem\"))\n                result += \"  Issue: Uses UnityEngine.InputSystem\\n\";\n            \n            // Count braces\n            int open = 0, close = 0;\n            foreach (char c in content)\n            {\n                if (c == '{') open++;\n                if (c == '}') close++;\n            }\n            result += $\"  Braces: open={open} close={close} match={open == close}\\n\";\n        }\n    }\n}\n\nreturn result;\n","safety_checks":true,"compiler":"auto"}}
