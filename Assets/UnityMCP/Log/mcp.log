{"ts":"2026-04-11T16:19:46.351Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":866,"action":"execute","params":{"action":"execute","code":"\n// Try opening scene directly via editor scripting\nUnityEditor.SceneManagement.EditorSceneManager.OpenScene(\"Assets/_FightForLife/Scenes/Island_flood_m.unity\", UnityEditor.SceneManagement.OpenSceneMode.Single);\nreturn $\"Scene: {UnityEngine.SceneManagement.SceneManager.GetActiveScene().name}\";\n","safety_checks":true,"compiler":"auto"}}
