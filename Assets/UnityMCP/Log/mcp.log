{"ts":"2026-04-11T20:13:19.113Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":10493,"action":"execute","params":{"action":"execute","code":"\nvar player = UnityEngine.GameObject.Find(\"Player\");\nvar pc = player.GetComponent<FightForLife.Player.PlayerController>();\nvar anim = player.GetComponentInChildren<UnityEngine.Animator>();\nvar fm = FightForLife.Disaster.FloodManager.Instance;\n\nvar info = anim.GetCurrentAnimatorStateInfo(0);\n\nreturn \"PlayerY=\" + player.transform.position.y.ToString(\"F2\") +\n    \"\\nWaterLevel=\" + (fm != null ? fm.WaterLevel.ToString(\"F2\") : \"null\") +\n    \"\\nWaterDepth=\" + pc.WaterDepth.ToString(\"F2\") +\n    \"\\nMovementState=\" + pc.CurrentState +\n    \"\\nIsSwimming=\" + pc.IsSwimming +\n    \"\\nIsGrounded=\" + pc.IsGrounded +\n    \"\\nAnim_IsSwimming=\" + anim.GetBool(\"IsSwimming\") +\n    \"\\nAnim_IsGrounded=\" + anim.GetBool(\"IsGrounded\") +\n    \"\\nAnim_StateHash=\" + info.shortNameHash +\n    \"\\nAnim_IsSwimState=\" + info.IsName(\"Swimming\") +\n    \"\\nAnim_IsLocoState=\" + info.IsName(\"Locomotion\") +\n    \"\\nAnim_IsJumpState=\" + info.IsName(\"Jump\") +\n    \"\\nAnim_InTransition=\" + anim.IsInTransition(0);\n","safety_checks":true,"compiler":"auto"}}
