{"ts":"2026-04-15T07:04:50.734Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":3849,"action":"execute","params":{"action":"execute","code":"// Aggressive per-scene cleanup of ALL missing MonoBehaviours.\nstring[] scenePaths = {\n    \"Assets/_FightForLife/Scenes/Island_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/Island_flood_m.unity\",\n    \"Assets/_FightForLife/Scenes/Village_Flood.unity\",\n    \"Assets/_FightForLife/Scenes/MainMenu.unity\",\n};\nstring report = \"\";\nforeach (var path in scenePaths) {\n    UnityEditor.SceneManagement.EditorSceneManager.OpenScene(path, UnityEditor.SceneManagement.OpenSceneMode.Single);\n    var scene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\n    int removed = 0;\n    int foundCount = 0;\n    var offenders = new System.Collections.Generic.List<string>();\n    System.Action<UnityEngine.Transform> walk = null;\n    walk = (t) => {\n        var go = t.gameObject;\n        int n = UnityEditor.GameObjectUtility.GetMonoBehavioursWithMissingScriptCount(go);\n        if (n > 0) {\n            foundCount += n;\n            offenders.Add(go.name+\"(+\"+n+\")\");\n            int r = UnityEditor.GameObjectUtility.RemoveMonoBehavioursWithMissingScript(go);\n            removed += r;\n        }\n        for (int i = 0; i < t.childCount; i++) walk(t.GetChild(i));\n    };\n    var roots = scene.GetRootGameObjects();\n    foreach (var r in roots) walk(r.transform);\n    if (removed > 0) {\n        UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scene);\n        UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scene);\n    }\n    report += path+\" found=\"+foundCount+\" removed=\"+removed+\"\\n\";\n    if (offenders.Count > 0) {\n        report += \"   offenders: \"+string.Join(\",\", offenders)+\"\\n\";\n    }\n}\nreturn report;","safety_checks":false,"compiler":"auto"}}
