{"ts":"2026-04-15T06:59:26.808Z","tool":"execute_code","type":"tool","status":"SUCCESS","ms":1269,"action":"execute","params":{"action":"execute","code":"// Open Island_flood_m and aggressively clean problem components\nvar targetPath = \"Assets/_FightForLife/Scenes/Island_flood_m.unity\";\nUnityEditor.SceneManagement.EditorSceneManager.OpenScene(targetPath, UnityEditor.SceneManagement.OpenSceneMode.Single);\nvar scene = UnityEditor.SceneManagement.EditorSceneManager.GetActiveScene();\n\nint mbRemoved = 0;\nint anyMissing = 0;\nint goTotal = 0;\nvar offendingNames = new System.Collections.Generic.List<string>();\n\nSystem.Action<UnityEngine.Transform> walk = null;\nwalk = (t) => {\n    goTotal++;\n    var go = t.gameObject;\n    // Missing MonoBehaviours\n    int mbMissing = UnityEditor.GameObjectUtility.GetMonoBehavioursWithMissingScriptCount(go);\n    if (mbMissing > 0) {\n        mbRemoved += UnityEditor.GameObjectUtility.RemoveMonoBehavioursWithMissingScript(go);\n        offendingNames.Add(go.name+\" (mb missing=\"+mbMissing+\")\");\n    }\n    // Any null component (non-MB)\n    var comps = go.GetComponents<UnityEngine.Component>();\n    foreach (var c in comps) if (c == null) anyMissing++;\n    foreach (UnityEngine.Transform child in t) walk(child);\n};\nforeach (var r in scene.GetRootGameObjects()) walk(r.transform);\n\nif (mbRemoved > 0) {\n    UnityEditor.SceneManagement.EditorSceneManager.MarkSceneDirty(scene);\n    UnityEditor.SceneManagement.EditorSceneManager.SaveScene(scene);\n}\nstring s = \"scene=\"+scene.path+\" totalGO=\"+goTotal+\" mbRemoved=\"+mbRemoved+\" anyMissing=\"+anyMissing+\"\\n\";\nif (offendingNames.Count > 0) {\n    s += \"offenders:\\n\";\n    for (int i=0;i<System.Math.Min(offendingNames.Count,20);i++) s += \"  \"+offendingNames[i]+\"\\n\";\n}\nreturn s;","safety_checks":true,"compiler":"auto"}}
